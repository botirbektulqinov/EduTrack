# EduTrack production environment template.
# Copy to .env on the server and replace every CHANGE_ME value.
# Do not commit .env.

APP_NAME=EduTrack
ENVIRONMENT=production
DEBUG=false
ENABLE_API_DOCS=false
API_V1_PREFIX=/api/v1

FRONTEND_URL=https://edutrack.systems
BACKEND_URL=https://edutrack.systems
CORS_ORIGINS=https://edutrack.systems,https://www.edutrack.systems

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_STRONG_SECRET_KEY
JWT_SECRET_KEY=CHANGE_ME_STRONG_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL runs inside docker-compose.prod.yml and is not published publicly.
POSTGRES_USER=edutrack
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=edu_track
DATABASE_URL=postgresql+asyncpg://edutrack:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/edu_track
DATABASE_URL_SYNC=postgresql+psycopg2://edutrack:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/edu_track

# Redis runs inside docker-compose.prod.yml and is not published publicly.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend build-time values.
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=/ws

# Email / password reset.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_TLS=true
SMTP_TIMEOUT_SECONDS=20
MAIL_FROM=noreply@edutrack.systems
MAIL_FROM_NAME=EduTrack
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_URL_PATH=/reset-password
ALLOW_PASSWORD_RESET_SIGNED_FALLBACK=false

# Optional object storage.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=edutrack-media

# Proctoring defaults.
DEFAULT_MAX_VIOLATIONS=3
DEFAULT_TIME_PENALTY_MINUTES=2

# Code execution preview is not a hardened sandbox. Do not run untrusted code
# in production until it is isolated in a dedicated sandbox.
SANDBOX_DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=256

# Rate limiting.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=20
RATE_LIMIT_FORGOT_PASSWORD_PER_HOUR=5
RATE_LIMIT_RESET_PASSWORD_PER_HOUR=10
RATE_LIMIT_ASSESSMENT_START_PER_MINUTE=5
RATE_LIMIT_ANSWER_SAVE_PER_MINUTE=60
RATE_LIMIT_CODE_PREVIEW_PER_MINUTE=5
RATE_LIMIT_WS_VIOLATION_PER_MINUTE=30
