# ===========================
# EduTrack Environment Config
# ===========================

# App
APP_NAME=EduTrack
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-me-in-production-abc123xyz789
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# Database (PostgreSQL 18)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=12431243aA
DB_NAME=edu_track
DATABASE_URL=postgresql+asyncpg://postgres:12431243aA@localhost:5432/edu_track
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:12431243aA@localhost:5432/edu_track

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=dev-jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@university.edu
SMTP_PASSWORD=
SMTP_TLS=true
MAIL_FROM=noreply@university.edu
MAIL_FROM_NAME=EduTrack

# Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edutrack-media

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Proctoring Defaults
DEFAULT_MAX_VIOLATIONS=3
DEFAULT_TIME_PENALTY_MINUTES=2

# Code Execution Sandbox
SANDBOX_DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=256

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
